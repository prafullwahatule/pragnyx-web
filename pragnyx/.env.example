# Copy this file to .env.local for local development, and add the same
# variables in your Vercel project settings (Settings → Environment Variables)
# for production. See ADMIN_SETUP.md for the full walkthrough.
#
# SECURITY NOTE: this file is a TEMPLATE — never put real secrets here.
# Real values belong only in .env.local (already in .gitignore) or your
# hosting provider's environment variable settings.

# Postgres connection string. Works with Neon (Vercel's native Postgres
# integration), Supabase, Railway, or any standard Postgres provider.
# Example (Neon): postgres://user:password@ep-xxxx.neon.tech/dbname?sslmode=require
DATABASE_URL=

# A long, random string used to sign admin session cookies.
# Generate one with: openssl rand -base64 32
ADMIN_SESSION_SECRET=

# A long, random string used to sign customer (workspace owner) session
# cookies for EduOS + FinCore dashboards. Use a DIFFERENT value from
# ADMIN_SESSION_SECRET. Generate one with: openssl rand -base64 32
CUSTOMER_SESSION_SECRET=

# Resend (https://resend.com) — powers welcome emails, demo request
# confirmations, and payment receipts for both EduOS and FinCore.
# Get a key from https://resend.com/api-keys after verifying a sending domain.
RESEND_API_KEY=

# Optional — override the default "From" address per product. Must be on a
# domain verified in your Resend account, or sends will fail.
EDUOS_EMAIL_FROM="PragnyX EduOS <onboarding@pragnyx.in>"
FINCORE_EMAIL_FROM="PragnyX FinCore <onboarding@pragnyx.in>"

# Bootstrap credentials for your FIRST login at /admin/login.
# After your first successful login, these are no longer used — the
# account lives in the database, and you can change the password from
# the admin panel itself. You can remove these two lines after that.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─────────────────────── PragnyX EduOS ───────────────────────
# Razorpay (get keys from https://dashboard.razorpay.com/app/keys)
# Test-mode keys work fine for local development.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Same secret you configure on the Razorpay webhook (Settings > Webhooks),
# pointed at https://yourdomain.com/api/eduos/webhook
RAZORPAY_WEBHOOK_SECRET=

# ─────────────────────── Analytics ───────────────────────
# Plausible (https://plausible.io) — privacy-friendly, cookieless site
# analytics. Set this to the exact domain the site is served on (e.g.
# pragnyx.in in production) and the tracking snippet in src/app/layout.js
# switches on automatically; leave it unset (e.g. in local dev) and
# nothing is loaded, no other code changes needed. If you're self-hosting
# Plausible instead of using their cloud, also set NEXT_PUBLIC_PLAUSIBLE_SRC
# to your instance's script URL.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=
