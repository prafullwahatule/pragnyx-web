# Copy this file to .env.local for local development, and add the same
# variables in your Vercel project settings (Settings → Environment Variables)
# for production. See ADMIN_SETUP.md for the full walkthrough.
#
# SECURITY NOTE: this file is a TEMPLATE — never put real secrets here.
# Real values belong only in .env.local (already in .gitignore) or your
# hosting provider's environment variable settings.

# Postgres connection string. Works with Neon (Vercel's native Postgres
# integration), Supabase, Railway, or any standard Postgres provider.
# Example (Neon): postgres://user:password@ep-xxxx.neon.tech/dbname?sslmode=require
DATABASE_URL=

# A long, random string used to sign admin session cookies.
# Generate one with: openssl rand -base64 32
ADMIN_SESSION_SECRET=

# Bootstrap credentials for your FIRST login at /admin/login.
# After your first successful login, these are no longer used — the
# account lives in the database, and you can change the password from
# the admin panel itself. You can remove these two lines after that.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─────────────────────── PragnyX EduOS ───────────────────────
# Razorpay (get keys from https://dashboard.razorpay.com/app/keys)
# Test-mode keys work fine for local development.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Same secret you configure on the Razorpay webhook (Settings > Webhooks),
# pointed at https://yourdomain.com/api/eduos/webhook
RAZORPAY_WEBHOOK_SECRET=
